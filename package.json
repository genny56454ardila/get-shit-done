{
  "name": "get-shit-done",
  "version": "1.0.0",
  "description": "A no-nonsense productivity CLI tool to block distracting websites and keep you focused",
  "main": "src/index.js",
  "bin": {
    "gsd": "./bin/gsd.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "productivity",
    "focus",
    "blocker",
    "cli",
    "distraction"
  ],
  "author": "get-shit-done contributors",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gsd-build/get-shit-done.git"
  },
  "bugs": {
    "url": "https://github.com/gsd-build/get-shit-done/issues"
  },
  "homepage": "https://github.com/gsd-build/get-shit-done#readme"
}
